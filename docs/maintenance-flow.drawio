        <mxCell id="s2p" value="split-claude-md&#10;A: rotate old decisions → monthly archives&#10;B: consolidate repeated gotchas&#10;C: extract stable reference files" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;html=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="445" y="390" width="290" height="110" as="geometry"/></mxCell>
