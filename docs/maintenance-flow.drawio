        <mxCell id="title" value="claude-maintenance-skills : keep a project's knowledge and your setup healthy" style="text;html=1;fontSize=20;fontStyle=1;fontColor=#0050b3;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1000" height="36" as="geometry"/></mxCell>

        <mxCell id="legend" value="Legend&#10;• green = when to reach for it&#10;• blue = skill (read-only orientation, or edits its own notes)&#10;• orange = output artifact&#10;Three independent utilities, used at different points in a project's life." style="rounded=0;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=0;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;whiteSpace=wrap;html=1;fontFamily=Helvetica;" vertex="1" parent="1"><mxGeometry x="1150" y="70" width="380" height="150" as="geometry"/></mxCell>

