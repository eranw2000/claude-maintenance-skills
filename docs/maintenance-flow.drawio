        <!-- STAGE 2: split-claude-md -->
        <mxCell id="s2" value="split-claude-md: keep the notes lean" style="rounded=0;fillColor=#fafafa;strokeColor=#0050b3;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;dashed=1;strokeWidth=2;html=1;" vertex="1" parent="1"><mxGeometry x="410" y="250" width="360" height="440" as="geometry"/></mxCell>
