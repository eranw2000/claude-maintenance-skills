        <mxCell id="s1t" value="returning after time away&#10;(&quot;where was I?&quot;)" style="ellipse;fillColor=#d5e8d4;strokeColor=#82b366;html=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="70" y="290" width="280" height="60" as="geometry"/></mxCell>
        <mxCell id="s1p" value="project-status&#10;gather: git state · open PRs · deploy health · local containers · project memory" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;html=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="70" y="390" width="280" height="110" as="geometry"/></mxCell>
